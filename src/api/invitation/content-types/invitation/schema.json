{
  "kind": "collectionType",
  "collectionName": "invitations",
  "info": {
    "singularName": "invitation",
    "pluralName": "invitations",
    "displayName": "Invitation",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "contactEmail": {
      "type": "email",
      "private": true
    },
    "householdName": {
      "type": "string"
    },
    "maxGuests": {
      "type": "integer"
    },
    "guests": {
      "type": "component",
      "component": "rsvp.guest",
      "repeatable": true,
      "max": 10
    },
    "messageToCouple": {
      "type": "text"
    },
    "rsvpStatus": {
      "type": "enumeration",
      "required": true,
      "default": "pending",
      "enum": [
        "pending",
        "confirmed",
        "declined"
      ]
    },
    "respondedAt": {
      "type": "datetime"
    },
    "code": {
      "type": "string",
      "unique": true
    },
    "inviteLink": {
      "type": "string"
    },
    "countAdult": {
      "type": "integer",
      "default": 0
    },
    "countChild": {
      "type": "integer",
      "default": 0
    },
    "countBaby": {
      "type": "integer",
      "default": 0
    },
    "countStandard": {
      "type": "integer",
      "default": 0
    },
    "countVegetarian": {
      "type": "integer",
      "default": 0
    },
    "countVegan": {
      "type": "integer",
      "default": 0
    },
    "countGlutenFree": {
      "type": "integer",
      "default": 0
    }
  }
}
