{
  "kind": "collectionType",
  "collectionName": "invitations",
  "info": {
    "singularName": "invitation",
    "pluralName": "invitations",
    "displayName": "Invitation",
    "description": ""
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "householdName": {
      "type": "string"
    },
    "maxGuests": {
      "type": "integer"
    },
    "rsvpStatus": {
      "type": "enumeration",
      "enum": ["pending", "confirmed", "declined"],
      "default": "pending",
      "required": true
    },
    "respondedAt": {
      "type": "datetime"
    },
    "messageToCouple": {
      "type": "text"
    },
    "confirmedAdultCount": {
      "type": "integer",
      "default": 0
    },
    "confirmedChildCount": {
      "type": "integer",
      "default": 0
    },
    "confirmedBabyCount": {
      "type": "integer",
      "default": 0
    },
    "guests": {
      "type": "component",
      "repeatable": true,
      "component": "rsvp.guest",
      "max": 10
    }
  }
}
